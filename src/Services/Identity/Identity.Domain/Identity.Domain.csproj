<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MediatR" />
    <!--
      Domain only needs IdentityUser<Guid> as a base class for ApplicationUser.
      That type lives in Microsoft.AspNetCore.Identity (core).
      Microsoft.AspNetCore.Identity.EntityFrameworkCore belongs in Infrastructure only
      (it adds IdentityDbContext, UserStore, EF table mappings - not domain concerns).
    -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Shared\UMS.SharedKernel\UMS.SharedKernel.csproj" />
  </ItemGroup>

</Project>
