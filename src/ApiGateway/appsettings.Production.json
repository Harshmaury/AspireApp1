{
  "Auth": {
    "Authority": "http://identity-api:8080",
    "Audience": "api-gateway",
    "RequireHttpsMetadata": false
  },
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://+:8080" }
    }
  },
  "Serilog": {
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://seq:5341" } }
    ]
  }
}
