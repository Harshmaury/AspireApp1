using Microsoft.EntityFrameworkCore;
using Npgsql;

namespace TenantIsolation.Tests.Helpers;

// TST-5 fix: EnsureCreated() fails for DbContexts whose OnModelCreating
// applies HasQueryFilter conditionally on _tenant?.IsResolved.
// When DbFactory constructs the context with no ITenantContext, IsResolved
// is false, so the filter block is skipped and EF builds a filter-free model.
// On some DbContexts this causes EnsureCreated() to generate a schema that
// does not match what the seeding code expects (wrong table names, missing
// columns), producing "relation does not exist" from Postgres.
//
// Fix: use EnsureDeleted() + EnsureCreated() on a context constructed with
// a resolved ITenantContext stub so OnModelCreating runs its full path and
// the correct schema is emitted. The stub tenant id is arbitrary — it is
// only used during schema creation, not during test queries.
public static class DbFactory
{
    // Sentinel tenant used only for schema creation — never for data isolation checks.
    private static readonly Guid SchemaTenantId = Guid.Parse("00000000-0000-0000-0000-000000000001");

    public static T Create<T>(
        Func<DbContextOptions<T>, T> ctor,
        string connectionString,
        string schemaName)
        where T : DbContext
    {
        // Strip hyphens — Postgres schema names cannot contain them unquoted
        var safeSchema = "t" + schemaName.Replace("-", "");

        var builder = new NpgsqlConnectionStringBuilder(connectionString)
        {
            SearchPath = safeSchema
        };

        var connStr = builder.ConnectionString;

        var opts = new DbContextOptionsBuilder<T>()
            .UseNpgsql(connStr)
            .Options;

        // Step 1: Create schema
        using (var schemaCtx = ctor(opts))
        {
            schemaCtx.Database.ExecuteSqlRaw($"CREATE SCHEMA IF NOT EXISTS \"{safeSchema}\"");
        }

        // Step 2: Try to create a tenant-resolved context for schema creation.
        // We attempt to construct via the two-parameter overload (options + ITenantContext)
        // using reflection. If the DbContext only has a single-parameter constructor,
        // fall back to the standard ctor — this covers contexts that don't use
        // HasQueryFilter at all.
        using (var createCtx = TryCreateWithTenantContext<T>(connStr, SchemaTenantId) ?? ctor(opts))
        {
            // EnsureCreated is idempotent — safe to call on every test.
            // Each test uses a unique schema (Guid-based), so there is no
            // cross-test contamination and no need to drop first.
            createCtx.Database.EnsureCreated();
        }

        // Step 3: Return the context the test will actually use (no tenant context —
        // the test controls tenant filtering via repository parameters).
        return ctor(opts);
    }

    // Attempts to construct a DbContext<T> that has ITenantContext injected
    // by looking for a two-parameter constructor: (DbContextOptions<T>, ITenantContext).
    // Returns null if no such constructor exists.
    private static T? TryCreateWithTenantContext<T>(string connectionString, Guid tenantId)
        where T : DbContext
    {
        var opts = new DbContextOptionsBuilder<T>()
            .UseNpgsql(connectionString)
            .Options;

        var tenantCtx = new StubTenantContext(tenantId);

        // Look for ctor(DbContextOptions<T>, ITenantContext?)
        // or      ctor(DbContextOptions<T>, ITenantContext)
        var ctor = typeof(T).GetConstructors()
            .FirstOrDefault(c =>
            {
                var p = c.GetParameters();
                return p.Length == 2
                    && p[0].ParameterType.IsAssignableFrom(typeof(DbContextOptions<T>))
                    && p[1].ParameterType.Name.Contains("ITenantContext");
            });

        if (ctor == null) return null;

        try
        {
            return (T)ctor.Invoke(new object?[] { opts, tenantCtx });
        }
        catch
        {
            return null;
        }
    }
}

// Minimal stub that satisfies ITenantContext with IsResolved = true.
// Only used during EnsureCreated() so the query filter lambda is registered.
// Implements the interface via duck typing — if the project uses a different
// ITenantContext interface, update the interface name and members below.
internal sealed class StubTenantContext : UMS.SharedKernel.Tenancy.ITenantContext
{
    private readonly Guid _tenantId;

    public StubTenantContext(Guid tenantId) => _tenantId = tenantId;

    public Guid TenantId => _tenantId;
    public bool IsResolved => true;
    public string TenantName => "test-tenant";
}
